# ---------------------------------------------------------------------------
# Supply-chain hardening: dependency "cooldown".
#
# min-release-age makes npm refuse to install any package version published less
# than N days ago. A freshly-published malicious release — from the 2025 npm
# attacks: self-replicating worms and hijacked maintainer accounts pushing
# trojaned patch versions — is usually detected and unpublished within hours to
# a day or two, so waiting 3 days keeps those out of our installs while costing
# us almost nothing. Applies at resolution time (install / update); `npm ci`
# from the lockfile is unaffected. Requires npm >= 11.10.0.
min-release-age=3

# Deliberately need a version younger than 3 days for a specific package?
# Override per-command (CLI flags beat this file); the policy still guards
# everything else:
#   npm install <pkg>@<version> --min-release-age=0
#   npm update  <pkg>           --min-release-age=0
# ---------------------------------------------------------------------------
